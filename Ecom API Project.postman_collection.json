  "item": [
    {
      "name": "Login API",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Login Successful\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "let jsonData=pm.response.json();\r",
              "pm.environment.set(\"token\",jsonData.accessToken);\r",
              "\r",
              "console.log(pm.environment.get(\"token\"));\r",
              "\r",
              "pm.test(\"Access token is present\", function () {\r",
              "    pm.expect(jsonData.accessToken).to.exist;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\": \"emilys\",\r\n    \"password\": \"emilyspass\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
